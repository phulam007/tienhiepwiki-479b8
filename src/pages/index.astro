---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Trang chủ">
  <main class="home">
    <h1>Chào mừng đến Tiên Hiệp Wiki</h1>
    <p>Kho tàng kiến thức về tiên hiệp, huyền huyễn</p>

    <div class="grid">
      <a href="/nhan-vat" class="card">
        <div class="icon">⚔️</div>
        <h2>Nhân vật</h2>
        <p>Danh sách nhân vật chính, phụ</p>
      </a>
      <a href="/bo-truyen" class="card">
        <div class="icon">📖</div>
        <h2>Bộ truyện</h2>
        <p>Phàm Nhân, Đấu Phá, Võ Động...</p>
      </a>
      <a href="/canh-gioi" class="card">
        <div class="icon">🌀</div>
        <h2>Cảnh giới</h2>
        <p>Hệ thống tu luyện, đột phá</p>
      </a>
      <a href="/thuat-ngu" class="card">
        <div class="icon">📚</div>
        <h2>Thuật ngữ</h2>
        <p>Kim Đan, Nguyên Anh, Linh Căn...</p>
      </a>
    </div>
  </main>
</Layout>

<style>
  .home { max-width: 960px; margin: 60px auto; padding: 0 24px; text-align: center; }
  h1 { font-size: 32px; color: #e2c97e; margin-bottom: 8px; }
  .home > p { color: #8888aa; margin-bottom: 40px; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .card {
    background: #1a1a2e;
    border: 1px solid #2a2a4e;
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    text-align: left;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: #c084fc; }
  .icon { font-size: 28px; margin-bottom: 12px; }
  .card h2 { font-size: 16px; color: #e2c97e; margin-bottom: 6px; }
  .card p { font-size: 13px; color: #8888aa; }
</style>
